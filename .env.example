# =========================
# Client
# =========================
# Public base URL of your backend proxy
VITE_API_BASE_URL=http://localhost:8787

# Default UI language: ru or en
VITE_DEFAULT_LOCALE=ru

# Optional feature flags
VITE_ENABLE_CAT_PLACEHOLDER=true
VITE_ENABLE_VOICE_INPUT=true
VITE_ENABLE_CLOUD_SYNC=false

# =========================
# Server
# =========================
NODE_ENV=development
PORT=8787

# OpenRouter
OPENROUTER_API_KEY=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 
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free 
